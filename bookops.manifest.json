{
  "format": "bookops-md",
  "version": 1,
  "book": {
    "slug": "ontahi",
    "title": "The Ontahí Language Kit",
    "subtitle": "A compact visual and editorial language for executable ontologies",
    "author": "Javier Fernandes",
    "language": "en"
  },
  "structure": {
    "kind": "numbered-folders-and-files",
    "partsAreNumberedFolders": true,
    "chaptersAreNumberedMarkdownFiles": true,
    "rootReadmeIsMetadataOnly": true
  },
  "bookops": {
    "recommendedMountPath": "docs/ontahi/book-of-style",
    "localAssets": true,
    "localAssetsPath": "/figures",
    "style": {
      "version": 1,
      "name": "ontahi-botanical-language",
      "tokens": {
        "color": {
          "background": "#F6F2EB",
          "foreground": "#1F2A24",
          "mutedForeground": "#5F746D",
          "surface": "#FBF8F0",
          "surfaceWarm": "#E8E2D3",
          "border": "#D9D1C0",
          "accent": "#D94C43",
          "accentSoft": "#F1B1AC",
          "organic": "#7A7F52",
          "forest": "#1F2A24"
        },
        "typography": {
          "heading": "Lora, ui-serif, Georgia, serif",
          "body": "Inter, ui-sans-serif, system-ui, sans-serif",
          "mono": "JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
        },
        "radius": {
          "panel": "8px",
          "control": "6px"
        }
      },
      "reader": {
        "content": {
          "background": "#FFFFFF",
          "foreground": "#1F2A24",
          "headingColor": "#0F252C",
          "captionColor": "#5F746D",
          "linkColor": "#D94C43"
        },
        "figure": {
          "background": "#F6F2EB",
          "border": "#E8E2D3",
          "captionColor": "#5F746D"
        },
        "code": {
          "background": "#F6F2EB",
          "border": "#D9D1C0",
          "foreground": "#1F2A24"
        }
      },
      "navigation": {
        "background": "#FFFFFF",
        "foreground": "#1F2A24",
        "mutedForeground": "#6F8580",
        "accent": "#D94C43",
        "activeBackground": "#E6F5F7",
        "border": "#D9E4E8"
      }
    }
  },
  "assets": {
    "logos": "assets/logo",
    "icons": "assets/icons",
    "patterns": "assets/patterns",
    "palette": "assets/palette",
    "specimens": "assets/specimens"
  },
  "parts": [
    {
      "path": "00-front-matter",
      "title": "Front Matter"
    },
    {
      "path": "01-foundation",
      "title": "Foundations"
    },
    {
      "path": "02-visual-grammar",
      "title": "Visual Grammar"
    },
    {
      "path": "03-botanical-language",
      "title": "Botanical Language"
    },
    {
      "path": "04-identity-system",
      "title": "Identity System"
    },
    {
      "path": "05-interface-editorial",
      "title": "Interface and Editorial"
    },
    {
      "path": "06-assets",
      "title": "Iconography and Assets"
    },
    {
      "path": "07-ai-agents",
      "title": "AI and Agents"
    }
  ],
  "designTokens": {
    "colors": {
      "forestDark": "#162018",
      "forest": "#1F2A24",
      "forestLight": "#2B382E",
      "oliveDark": "#465538",
      "olive": "#7A7F52",
      "oliveLight": "#98A16B",
      "ceibo": "#D94C43",
      "ceiboLight": "#E06A61",
      "ceiboSoft": "#F1B1AC",
      "paper": "#F6F2EB",
      "warmPaper": "#E8E2D3",
      "paperShade": "#D9D1C0",
      "paperDeep": "#C2B7A4"
    }
  }
}
